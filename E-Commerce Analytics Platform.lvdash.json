{
  "datasets": [
    {
      "name": "b61b5e08",
      "displayName": "Daily Revenue & Sales Trends",
      "queryLines": [
        "SELECT\r\n",
        "    event_date,\r\n",
        "    SUM(transaction_amount) as total_revenue,\r\n",
        "    COUNT(transaction_amount) as total_transactions,\r\n",
        "    COUNT(DISTINCT user_id) as unique_shoppers\r\n",
        "FROM ecommerce_analytics_dev.gold_layer.gold_fact_sales\r\n",
        "WHERE event_type = 'purchase'\r\n",
        "GROUP BY event_date\r\n",
        "ORDER BY event_date;"
      ],
      "catalog": "ecommerce_analytics_dev",
      "schema": "default"
    },
    {
      "name": "0e1f7c10",
      "displayName": "Top 10 Brands by Revenue",
      "queryLines": [
        "SELECT\r\n",
        "    brand,\r\n",
        "    SUM(transaction_amount) as total_revenue,\r\n",
        "    AVG(transaction_amount) as avg_order_value\r\n",
        "FROM ecommerce_analytics_dev.gold_layer.gold_fact_sales\r\n",
        "WHERE event_type = 'purchase' AND brand IS NOT NULL\r\n",
        "GROUP BY brand\r\n",
        "ORDER BY total_revenue DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "451e5431",
      "displayName": "Product Price History (SCD Type 2 Proof)",
      "queryLines": [
        "SELECT\r\n",
        "    product_id,\r\n",
        "    brand,\r\n",
        "    price as catalog_price,\r\n",
        "    __START_AT as valid_from,\r\n",
        "    __END_AT as valid_until\r\n",
        "FROM ecommerce_analytics_dev.gold_layer.gold_dim_products\r\n",
        "WHERE product_id IN (\r\n",
        "    -- Subquery to find a product that actually changed price\r\n",
        "    SELECT product_id FROM ecommerce_analytics_dev.gold_layer.gold_dim_products\r\n",
        "    GROUP BY product_id HAVING COUNT(*) > 1\r\n",
        ")\r\n",
        "ORDER BY product_id, __START_AT\r\n",
        "LIMIT 100;"
      ]
    },
    {
      "name": "3d18ee9c",
      "displayName": "Customer Journey Analysis",
      "queryLines": [
        "-- CUSTOMER JOURNEY FUNNEL\r\n",
        "-- Shows how many people View -> Cart -> Purchase\r\n",
        "SELECT \r\n",
        "    CASE \r\n",
        "        WHEN event_type = 'view' THEN '1. View Product'\r\n",
        "        WHEN event_type = 'cart' THEN '2. Add to Cart'\r\n",
        "        WHEN event_type = 'purchase' THEN '3. Purchase'\r\n",
        "    END as funnel_stage,\r\n",
        "    COUNT(DISTINCT user_id) as user_count,\r\n",
        "    -- Calculate drop-off percentage relative to Views\r\n",
        "    ROUND(COUNT(DISTINCT user_id) * 100.0 / (SELECT COUNT(DISTINCT user_id) FROM ecommerce_analytics_dev.gold_layer.gold_fact_sales WHERE event_type = 'view'), 1) as conversion_pct\r\n",
        "FROM ecommerce_analytics_dev.gold_layer.gold_fact_sales\r\n",
        "WHERE event_type IN ('view', 'cart', 'purchase')\r\n",
        "GROUP BY 1\r\n",
        "ORDER BY 1;"
      ],
      "catalog": "ecommerce_analytics_dev",
      "schema": "default"
    },
    {
      "name": "ad379d87",
      "displayName": "Product Performance Metrics",
      "queryLines": [
        "-- PRODUCT PERFORMANCE & CONVERSION RATES\r\n",
        "SELECT \r\n",
        "    brand,\r\n",
        "    -- Metric 1: Revenue\r\n",
        "    SUM(CASE WHEN event_type = 'purchase' THEN transaction_amount ELSE 0 END) as total_revenue,\r\n",
        "    \r\n",
        "    -- Metric 2: Demand (High views = High potential inventory need)\r\n",
        "    COUNT(CASE WHEN event_type = 'view' THEN 1 END) as total_views,\r\n",
        "    \r\n",
        "    -- Metric 3: Conversion Rate (Purchases / Views)\r\n",
        "    -- Protect against division by zero\r\n",
        "    ROUND(\r\n",
        "        SUM(CASE WHEN event_type = 'purchase' THEN 1 ELSE 0 END) * 100.0 / \r\n",
        "        NULLIF(COUNT(CASE WHEN event_type = 'view' THEN 1 END), 0)\r\n",
        "    , 2) as conversion_rate_pct\r\n",
        "FROM ecommerce_analytics_dev.gold_layer.gold_fact_sales\r\n",
        "WHERE brand IS NOT NULL AND brand != 'Unknown'\r\n",
        "GROUP BY brand\r\n",
        "HAVING total_views > 1000 -- Filter for significant data\r\n",
        "ORDER BY total_revenue DESC\r\n",
        "LIMIT 20;"
      ],
      "catalog": "ecommerce_analytics_dev",
      "schema": "default"
    },
    {
      "name": "eba8cae3",
      "displayName": "Real-time Dashboards",
      "queryLines": [
        "-- LIVE SALES TICKER (Simulated for Historical Data)\r\n",
        "-- This finds the latest data you actually have and shows the \"last 24 hours\" of that period.\r\n",
        "\r\n",
        "WITH MaxDate AS (\r\n",
        "    SELECT MAX(event_time) as max_time \r\n",
        "    FROM ecommerce_analytics_dev.gold_layer.gold_fact_sales\r\n",
        ")\r\n",
        "SELECT \r\n",
        "    hour(event_time) as hour_of_day,\r\n",
        "    SUM(transaction_amount) as hourly_revenue,\r\n",
        "    COUNT(CASE WHEN event_type = 'purchase' THEN 1 END) as sales_velocity\r\n",
        "FROM ecommerce_analytics_dev.gold_layer.gold_fact_sales, MaxDate\r\n",
        "WHERE event_time >= MaxDate.max_time - INTERVAL 24 HOURS\r\n",
        "GROUP BY 1\r\n",
        "ORDER BY 1;"
      ],
      "catalog": "ecommerce_analytics_dev",
      "schema": "default"
    }
  ],
